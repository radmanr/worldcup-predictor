# Postgres connection strings.
# DATABASE_URL = POOLED connection (host contains "-pooler") — used by the app.
# DIRECT_URL   = DIRECT connection (no "-pooler") — used by `prisma db push`/seed.
# With Neon, get both from the "Connect" modal by toggling the pooler switch.
# If you use a plain (non-serverless) Postgres, set both to the same value.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Secret used to sign login session tokens. Use a long random string.
AUTH_SECRET="change-me-to-a-long-random-string"

# Credentials for the built-in admin account created by the seed script.
ADMIN_NAME="Admin"
ADMIN_EMAIL="admin@yourcompany.com"
ADMIN_PASSWORD="change-this-password"

# Secret code colleagues must enter to register (keeps the game internal).
# Leave blank to allow open registration.
REGISTRATION_CODE="GOALS2026"
